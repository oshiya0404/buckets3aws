{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": ["s3:PutObject"],
        "Resource": "arn:aws:s3:::oshiyas3/notes/*"
      },
      {
        "Effect": "Allow",
        "Action": ["s3:ListBucket"],
        "Resource": "arn:aws:s3:::oshiyas3",
        "Condition": {
          "StringLike": {
            "s3:prefix": ["notes/*"]
          }
        }
      }
    ]
  }